[
  {
    "height": 20,
    "position": "top",
    "layer": "top",

    "modules-left": [
      "niri/workspaces",
      "niri/window"
    ],

    "modules-center": [],

    "modules-right": [
      "niri/language",
      "cpu",
      "memory",
      "disk",
      "mpd",
      "custom/weather",
      "pulseaudio",
      "clock",
      "tray"
    ],

    "niri/workspaces": {
      "format": "{index}",
      "persistent-workspaces": {
        "*": 9
      },
      "all-outputs": true
    },

    "niri/window": {
      "format": "| {title}",
      "max-length": 35
    },

    "niri/language": {
      "format-en": "English (US)",
      "format-ru": "Russian"
    },

    "cpu": {
      "format": "|{usage}%",
      "interval": 10
    },

    "memory": {
      "format": "|{}%",
      "interval": 30
    },

    "disk": {
      "format": "|{used}",
      "path": "/home",
      "interval": 60
    },

    "mpd": {
      "format": "|{stateIcon} {artist} - {title}",
      "format-disconnected": "|󰝛",
      "format-stopped": "|󰝛",
      "state-icons": {
        "playing": "",
        "paused": "󰏤"
      },
      "max-length": 30,
      "interval": 1, 
      "consume-icons": { "on": " " },
      "random-icons": { "on": " " },
      "repeat-icons": { "on": " " },
      "single-icons": { "on": "1 " },
      "on-click": "mpc toggle",
      "on-click-right": "mpc next",
      "on-click-middle": "mpc prev",
      "on-scroll-up": "mpc volume +2",
      "on-scroll-down": "mpc volume -2"
    },

    "custom/weather": {
      "exec": "curl -s 'wttr.in/Mednogorsk?format=%c%t'",
      "format": "|{} ",
      "interval": 300
    },

    "pulseaudio": {
      "format": "|{icon} {volume}%",
      "format-icons": {
        "default": ["", ""],
        "headphones": ""
      },
      "format-muted": "|"
    },

    "clock": {
      "format": "|{:%A, %d %b %H:%M}",
      "format-alt": "|{:%A, %B %d, %Y}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "tray": {
      "icon-size": 14,
      "spacing": 4
    }
  }
]
